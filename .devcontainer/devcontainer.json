{
  "name": "LTL Tool Detection, Planner, and Booker Dev Container",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/dotnet:2": { "version": "10" },
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "docker compose up -d",
  "forwardPorts": [4200, 5072, 14333],
  "portsAttributes": {
    "4200": { "label": "Web App", "onAutoForward": "openBrowser", "visibility": "private" },
    "5072": { "label": "API", "onAutoForward": "notify", "visibility": "private" },
    "14333": { "label": "SQL Server", "onAutoForward": "ignore", "visibility": "private" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "angular.ng-template",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
