# .env.demo.example — LTL local demo (no Azure, no Entra).
#
# Copy this file to `.env` and fill in the Alvys credentials block. Then run
# `./scripts/demo-up.sh` (macOS/Linux) or `pwsh ./scripts/demo-up.ps1` (Windows).
#
# What this configuration does:
#   - Auth: bypasses Entra ID entirely via AccessPolicy:Mode=Demo. Every API
#     request is authenticated as demo@valuetruck.com. Never deploy this
#     configuration to a public-facing environment.
#   - Data: reads live Alvys tenant va336 (the Value Truck production tenant).
#           Writes are disabled at the API's writeback boundary.
#   - Local runtime: SQL Server 2022 in Docker, .NET 10 API on :5072, Angular
#     SPA on :4200.

# -------- Auth mode --------
ACCESS_POLICY_MODE=Demo

# Leave the Entra IDs empty. The Angular app's isAuthConfigured() check will
# skip MSAL when these are blank; the API's DemoAuthenticationHandler will
# admit every request.
AZURE_AD_TENANT_ID=
AZURE_AD_API_CLIENT_ID=
AZURE_AD_WEB_CLIENT_ID=
AZURE_AD_API_SCOPE=
AZURE_AD_CLIENT_SECRET=

# Empty allow-list = any authenticated caller admitted. Demo mode's synthetic
# identity is demo@valuetruck.com, so setting this to `valuetruck.com` also
# works and is a small extra defense.
ALLOWED_EMAIL_DOMAIN=

# -------- SQL Server --------
MSSQL_SA_PASSWORD=Your_strong_Password123!

# -------- Alvys (Value Truck va336, live reads) --------
# Same credentials as your working Alvys MCP connector.
ALVYS_PROVIDER=Live
ALVYS_API_BASE_URL=https://integrations.alvys.com
ALVYS_API_VERSION=v1
ALVYS_TENANT_ID=va336
ALVYS_CLIENT_ID=MZEDvQYVZmcEtk3f17QFgYTg19pa3eJL
ALVYS_CLIENT_SECRET=<paste your Alvys client secret here>

# Writeback stays hard-disabled for the demo — reads only.
ALVYS_WRITEBACK_MODE=Disabled

# -------- LTL app --------
LTL_DETECTION_ENABLED=true
LTL_DEFAULT_TIMEZONE=America/Chicago
