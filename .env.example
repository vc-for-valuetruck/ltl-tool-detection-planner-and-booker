# ─────────────────────────────────────────────
# UAT Template Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# Microsoft Entra ID
AZURE_AD_TENANT_ID=
AZURE_AD_API_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_WEB_CLIENT_ID=
AZURE_AD_API_SCOPE=

# Email domain allow-list (comma-separated for multiple)
ALLOWED_EMAIL_DOMAIN=example.com

# SQL Server (Docker)
MSSQL_SA_PASSWORD=Your_strong_Password123!

# External API (optional)
EXTERNAL_API_BASE_URL=
EXTERNAL_API_KEY=

# ─────────────────────────────────────────────
# ngrok public demo (optional — used by ./start-demo.sh and
# docker-compose.demo.yml to expose the stack over a public HTTPS URL).
# Get a free token at https://dashboard.ngrok.com/get-started/your-authtoken
# NEVER commit a real authtoken. If one leaks, rotate it immediately.
# ─────────────────────────────────────────────
NGROK_AUTHTOKEN=
# Optional reserved domain (ngrok paid) for a stable URL across restarts.
NGROK_DOMAIN=
# Set automatically by start-demo.sh — leave blank.
PUBLIC_URL=
