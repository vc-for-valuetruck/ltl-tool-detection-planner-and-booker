# ─────────────────────────────────────────────
# UAT Template Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# Microsoft Entra ID
AZURE_AD_TENANT_ID=
AZURE_AD_API_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_WEB_CLIENT_ID=
AZURE_AD_API_SCOPE=

# Email domain allow-list (comma-separated for multiple)
ALLOWED_EMAIL_DOMAIN=example.com

# SQL Server (Docker)
MSSQL_SA_PASSWORD=Your_strong_Password123!

# External API (optional)
EXTERNAL_API_BASE_URL=
EXTERNAL_API_KEY=

# ─────────────────────────────────────────────
# Alvys TMS integration (API only — NEVER exposed to the Angular SPA).
# Live Alvys is the default source of truth. Set ALVYS_PROVIDER=Fallback for
# local/UAT runs without a live tenant (returns empty results, never default in prod).
# Credentials must stay server-side only.
# ─────────────────────────────────────────────
ALVYS_PROVIDER=Live
ALVYS_API_BASE_URL=https://integrations.alvys.com
ALVYS_API_VERSION=v1
ALVYS_TENANT_ID=
ALVYS_CLIENT_ID=
ALVYS_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Alvys writeback boundary (API only — NEVER exposed to the SPA).
# Sandbox-gated. Default Disabled so a fresh clone / CI / production never writes
# back to Alvys. No live Alvys mutation is performed in this phase regardless of mode:
#   Disabled   → operations are audit-only (payload recorded, never sent).
#   Simulation → dry-run only (payload built/validated for preview, never sent).
#   Sandbox    → eligible for non-production sandbox execution, but further gated by a
#                recognised sandbox environment + a non-production sandbox base URL +
#                credentials. Even when fully configured, operations stay "unsupported"
#                until a documented Alvys mutating endpoint is wired.
# ALVYS_WRITEBACK_ENVIRONMENT must be one of: sandbox, uat, staging, test.
# ALVYS_WRITEBACK_SANDBOX_BASE_URL must NOT be the production host (integrations.alvys.com).
# ─────────────────────────────────────────────
ALVYS_WRITEBACK_MODE=Disabled
ALVYS_WRITEBACK_ENVIRONMENT=
ALVYS_WRITEBACK_SANDBOX_BASE_URL=

# ─────────────────────────────────────────────
# LTL tool app settings (API only). Safe defaults for first run.
# ─────────────────────────────────────────────
LTL_DETECTION_ENABLED=false
LTL_DEFAULT_TIMEZONE=America/Chicago

# ─────────────────────────────────────────────
# Accessorial Signal AI (Phase 6 — disabled by default).
# Set LTL__ACCESSORIALAI__ENABLED=true and supply credentials to activate Azure OpenAI
# extraction. Credentials are server-side only — NEVER expose to the Angular SPA,
# NEVER commit real values to source or docs.
# ─────────────────────────────────────────────
LTL__ACCESSORIALAI__ENABLED=false
LTL__ACCESSORIALAI__ENDPOINT=
LTL__ACCESSORIALAI__DEPLOYMENTNAME=
LTL__ACCESSORIALAI__APIKEY=

# ─────────────────────────────────────────────
# Trailer-fit packing sidecar (Phase 2 M2 — disabled by default).
# When off, the API runs the NullTrailerFitService and the plan-detail page shows
# "verify at dock". Set LTL_TRAILER_FIT_ENABLED=true to route plan previews through the
# packing sidecar (docker-compose starts it as the `trailer-fit` service). The sidecar is
# pure compute: it receives only dimensions/weights the API already holds — never Alvys
# identifiers or credentials.
# ─────────────────────────────────────────────
LTL_TRAILER_FIT_ENABLED=false
LTL_TRAILER_FIT_BASE_URL=http://trailer-fit:8080

# ─────────────────────────────────────────────
# Hosting
# This file configures LOCAL development only (docker-compose / dotnet run).
# The deployed app is hosted in Azure (Container Apps + Azure SQL + Key Vault).
# Cloud configuration is supplied via GitHub Actions environment variables/secrets
# and Azure App Settings / Key Vault references — NOT this file. No secrets in repo.
# See docs/AZURE_HOSTING.md for the required GitHub vars/secrets and OIDC setup.
# ─────────────────────────────────────────────
